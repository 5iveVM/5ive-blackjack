# Optional: canonical session manager for your VM (derived automatically if omitted)
# NEXT_PUBLIC_SESSION_MANAGER_SCRIPT_ACCOUNT=
# Optional: set to 1 to use delegated session signer for hit/stand; default is direct-owner mode for reliability.
# NEXT_PUBLIC_ENABLE_DELEGATED_SESSION_ACTIONS=0
# Optional: set to 1 to allow automatic direct-wallet fallback when delegated session auth fails.
# Leave at 0 to keep session mode strict and never silently switch to wallet signing.
# NEXT_PUBLIC_ENABLE_SESSION_DIRECT_FALLBACK=0
# Optional fixed game accounts; leave blank to use Provision Accounts in UI
# NEXT_PUBLIC_BJ_TABLE_ACCOUNT=
# NEXT_PUBLIC_BJ_PLAYER_ACCOUNT=
# NEXT_PUBLIC_BJ_ROUND_ACCOUNT=
# Optional per-network fixed game accounts (preferred over shared keys above)
# NEXT_PUBLIC_BJ_TABLE_ACCOUNT_DEVNET=
